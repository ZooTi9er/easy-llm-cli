# Easy LLM CLI 自定义 API 配置示例
# 
# 使用方法：
# 1. 复制此文件为 .gemini/.env
# 2. 修改相应的配置值
# 3. 运行 elc

# === 基础配置 ===
# 启用自定义 LLM (必需)
USE_CUSTOM_LLM=true

# LLM 提供商类型 (通常为 "openai" 兼容格式)
CUSTOM_LLM_PROVIDER="openai"

# === 认证配置 ===
# 您的 API 密钥 (必需)
CUSTOM_LLM_API_KEY="your-api-key-here"

# === API 端点配置 ===
# API 服务地址 (必需)
CUSTOM_LLM_ENDPOINT="https://your-api-endpoint.com/v1"

# === 模型配置 ===
# 使用的模型名称 (必需)
CUSTOM_LLM_MODEL_NAME="your-model-name"

# === 可选参数 ===
# 温度参数 (0-2, 默认 0)
CUSTOM_LLM_TEMPERATURE=0.7

# 最大令牌数 (默认 8192)
CUSTOM_LLM_MAX_TOKENS=8192

# Top-P 参数 (0-1, 默认 1)
CUSTOM_LLM_TOP_P=1.0

# 请求超时时间 (毫秒，默认 30000)
CUSTOM_LLM_TIMEOUT=30000

# === Gemini 1.5 Flash 优化配置 ===
# Flash 模型响应更快，可以适当调整参数
# CUSTOM_LLM_TEMPERATURE=0.1  # 技术任务建议使用低温度
# CUSTOM_LLM_TIMEOUT=30000   # Flash 模型响应更快，30秒足够
# CUSTOM_LLM_MAX_TOKENS=8192  # Flash 模型可以处理更多令牌

# === 常见配置示例 ===

# 示例 1: DeepSeek API
# USE_CUSTOM_LLM=true
# CUSTOM_LLM_PROVIDER="openai"
# CUSTOM_LLM_API_KEY="sk-your-deepseek-key"
# CUSTOM_LLM_ENDPOINT="https://api.deepseek.com/v1"
# CUSTOM_LLM_MODEL_NAME="deepseek-chat"
# CUSTOM_LLM_TEMPERATURE=0.1

# 示例 2: OpenAI API
# USE_CUSTOM_LLM=true
# CUSTOM_LLM_PROVIDER="openai"
# CUSTOM_LLM_API_KEY="sk-your-openai-key"
# CUSTOM_LLM_ENDPOINT="https://api.openai.com/v1"
# CUSTOM_LLM_MODEL_NAME="gpt-4"
# CUSTOM_LLM_TEMPERATURE=0.7

# 示例 3: 自部署模型 (ClawCloud)
# USE_CUSTOM_LLM=true
# CUSTOM_LLM_PROVIDER="openai"
# CUSTOM_LLM_API_KEY="your-custom-key"
# CUSTOM_LLM_ENDPOINT="https://your-domain.com/v1"
# CUSTOM_LLM_MODEL_NAME="gemini-1.5-flash"
# CUSTOM_LLM_TEMPERATURE=0.1

# 示例 4: 本地模型 (Ollama)
# USE_CUSTOM_LLM=true
# CUSTOM_LLM_PROVIDER="openai"
# CUSTOM_LLM_API_KEY="ollama"
# CUSTOM_LLM_ENDPOINT="http://localhost:11434/v1"
# CUSTOM_LLM_MODEL_NAME="llama3.1:8b"
# CUSTOM_LLM_TEMPERATURE=0.7

# === 使用说明 ===
# 
# 1. 创建配置文件：
#    mkdir -p .gemini
#    cp custom-api-config.env .gemini/.env
#
# 2. 编辑配置：
#    nano .gemini/.env
#
# 3. 验证配置：
#    ./check-config.sh
#
# 4. 启动 CLI：
#    elc
#
# === 故障排除 ===
#
# 如果遇到问题，请检查：
# 1. 所有必需的环境变量是否已设置
# 2. API 密钥是否正确
# 3. API 端点是否可访问
# 4. 模型名称是否存在于该 API 中
#
# 运行调试模式：
# elc --debug
#
# 检查配置：
# ./check-config.sh
#
# 诊断 API 问题：
# ./diagnose-api.sh